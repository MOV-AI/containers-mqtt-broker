<?xml version="1.0"?>
<hivemq xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="config.xsd">

    <!-- =============================================== -->
    <!-- HiveMQ Community Edition 2025.5 Configuration -->
    <!-- Optimized for Robot Fleet Management          -->
    <!-- =============================================== -->

    <!-- MQTT Configuration -->
    <mqtt>
        <!-- Session expiry interval for robot connections (24 hours) -->
        <session-expiry>
            <max-interval>86400</max-interval>
        </session-expiry>

        <!-- Message expiry for retained messages (7 days) -->
        <message-expiry>
            <max-interval>604800</max-interval>
        </message-expiry>

        <!-- Quality of Service -->
        <quality-of-service>
            <!-- Maximum QoS level (0, 1, 2) -->
            <max-qos>2</max-qos>
        </quality-of-service>

        <!-- Topic alias for efficient communication -->
        <topic-alias>
            <enabled>true</enabled>
            <max-per-client>100</max-per-client>
        </topic-alias>

        <!-- Subscription identifier support -->
        <subscription-identifier>
            <enabled>true</enabled>
        </subscription-identifier>

        <!-- Wildcard subscriptions -->
        <wildcard-subscriptions>
            <enabled>true</enabled>
        </wildcard-subscriptions>

        <!-- Shared subscriptions for load balancing -->
        <shared-subscriptions>
            <enabled>true</enabled>
        </shared-subscriptions>

        <!-- Retained messages -->
        <retained-messages>
            <enabled>true</enabled>
        </retained-messages>

        <!-- Keep alive settings for robot connections -->
        <keep-alive>
            <max-keep-alive>600</max-keep-alive>
            <allow-unlimited>false</allow-unlimited>
        </keep-alive>
    </mqtt>

    <!-- Listeners Configuration -->
    <listeners>
        <!-- Standard MQTT TCP Listener -->
        <tcp-listener>
            <port>1883</port>
            <bind-address>0.0.0.0</bind-address>
            <name>mqtt-tcp</name>

            <!-- Connection settings optimized for robot fleets -->
            <connect-overload-protection>
                <enabled>true</enabled>
                <threshold>50</threshold>
            </connect-overload-protection>

            <!-- No delay for real-time robot communication -->
            <no-delay>true</no-delay>
        </tcp-listener>

        <!-- Secure MQTT TLS Listener for production robots -->
